events:
    - TRANSACTION_CREATED
    - TRANSACTION_STATE_CHANGED

    - DOCUMENT_UPLOADED
    - DOCUMENT_APPROVED
    - DOCUMENT_REJECTED_WITH_NOTES

    - CONTRACT_UPLOADED
    - CONTRACT_SIGNED
    - CONTRACT_VOIDED
    
    - PROPOSAL_SUBMITTED
    - PROPOSAL_APPROVED
    - PROPOSAL_REJECTED_WITH_NOTES

    - event       : Event
    - actor       : Party
    - occurredAt  : Time
    - resourceId  : Optional Text

interaction:
    - ''Property Purchase

    - roles:
        - Agent
        - Buyer

        - Agent sends a purchase proposal for Buyer to accept
        - Agents sends contracts for both to sign

    - metrics:
        - ''Agent
        - Reliability:
            - Transaction completion
            - Voided contract ratio
        - Responsiveness:
            - Time from proposal acceptance to contract upload
            - Contract Signing speed
        - Accuracy:
            - Proposal acceptance rate

        - ''Buyer
        - Reliability:
            - Contract signing rate
        - Responsiveness:
            - Proposal response time
            - Contract Signing speed
        - Accuracy:
            - Proposal round efficiency 



    - ''Rental Agreement

    - roles:
        - Landlord
        - Tenant

        - Tenant uploads documents for the Landlord to review
        - Landlord approves or reject 

    - metrics:
        - ''Landlord
        - Reliability:
            - Document evaluation completion rate
        - Responsiveness:
            - Document evaluation speed
        - Accuracy:
            - Single-round clearnace rate 

        - ''Tenant
        - Reliability:
            - Dropout rate after proposal acceptance
        - Responsiveness:
            - Time to first document upload
            - Re-upload speed after rejection
        - Accuracy:
            - Attempts per approved document




