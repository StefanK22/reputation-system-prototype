-- Round 3: BuyerEager — Modern apartment in a popular neighbourhood; buyer ready to move quickly.
module Scripts.EvalSeedAgentRound3 where

import Daml.Script
import DA.Time (time)
import DA.Date (date, Month(..))
import DA.Text (isPrefixOf)

import Reputation.PropertyPurchase.Configuration (PropertyPurchaseConfiguration(..))
import Reputation.PropertyPurchase.Configuration qualified as PP
import Reputation.Interaction.Draft (DraftInteraction(..), Begin(..))
import Reputation.Interaction.InProgress (RecordEvent(..), Complete(..))
import Reputation.Interface.Configuration qualified as Configuration (I)
import Reputation.Types
import Reputation.PropertyPurchase.Feedback (PropertyPurchaseFeedbackRequest, SubmitFeedback(..))

evalSeedAgentRound3 : Script ()
evalSeedAgentRound3 = do

  -- ── Look up parties ───────────────────────────────────────────────
  knownParties <- listKnownParties
  let lookupParty name = case find (\pd -> (name <> "::") `isPrefixOf` (partyToText pd.party)) knownParties of
        None -> fail $ "Party not found: " <> name
        Some pd -> pure pd.party

  operator         <- case find (\pd -> "Operator::" `isPrefixOf` (partyToText pd.party)) knownParties of
    None -> fail "Operator party not found."
    Some pd -> pure pd.party
  agentHighReject    <- lookupParty "AgentHighReject"
  agentPro           <- lookupParty "AgentPro"
  agentSlowUploader  <- lookupParty "AgentSlowUploader"
  agentUnreliable    <- lookupParty "AgentUnreliable"
  buyerEager         <- lookupParty "BuyerEager"

  -- ── Look up PP config ─────────────────────────────────────────────
  ppConfigs <- query @PropertyPurchaseConfiguration operator
  ppConfigCid <- case find (\(_, c) -> c.configId == "EVAL-PP-CONFIG") ppConfigs of
    None -> fail "PropertyPurchaseConfiguration 'EVAL-PP-CONFIG' not found. Run EvalSeedAgentSetup first."
    Some (cid, _) -> pure cid
  let iPPConfigCid : ContractId Configuration.I = toInterfaceContractId ppConfigCid

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-009: AgentPro (Agent) + BuyerEager (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_009_t0 = time (date 2027 Sep 24) 9 0 0
      tx_eval_009_p1_submit  = time (date 2027 Sep 24) 9 0 0
      tx_eval_009_p1_respond = time (date 2027 Sep 24) 11 0 0
      tx_eval_009_cu1          = time (date 2027 Sep 24) 14 0 0
      tx_eval_009_contract_sign   = time (date 2027 Sep 24) 18 0 0
      tx_eval_009_close    = time (date 2027 Sep 24) 19 0 0
      tx_eval_009_complete = time (date 2027 Sep 24) 20 0 0
      tx_eval_009_feedback = time (date 2027 Sep 25) 20 0 0

  tx_eval_009_draftCid <- submit agentPro do
    createCmd DraftInteraction with
      operator; initiator = agentPro; initiatorRole = Agent
      interactionId = "TX-EVAL-009"
      interactionType = "PropertyPurchase"
      participants = [(buyerEager, Buyer)]
      openedAt = tx_eval_009_t0

  tx_eval_009_ipCid <- submit agentPro do
    exerciseCmd tx_eval_009_draftCid Begin with startedAt = tx_eval_009_t0; configCid = iPPConfigCid

  tx_eval_009_ipCid <- submit operator do
    exerciseCmd tx_eval_009_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentPro; occurredAt = tx_eval_009_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_009_ipCid <- submit operator do
    exerciseCmd tx_eval_009_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerEager; occurredAt = tx_eval_009_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_009_ipCid <- submit operator do
    exerciseCmd tx_eval_009_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentPro; occurredAt = tx_eval_009_cu1
        resourceId = Some "contract-001"

  tx_eval_009_ipCid <- submit operator do
    exerciseCmd tx_eval_009_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = agentPro; occurredAt = tx_eval_009_contract_sign
        resourceId = Some "contract-001"

  tx_eval_009_ipCid <- submit operator do
    exerciseCmd tx_eval_009_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = buyerEager; occurredAt = tx_eval_009_contract_sign
        resourceId = Some "contract-001"

  tx_eval_009_ipCid <- submit operator do
    exerciseCmd tx_eval_009_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentPro; occurredAt = tx_eval_009_close
        resourceId = Some "SELL_CLOSED"

  tx_eval_009_completedCid <- submit agentPro do
    exerciseCmd tx_eval_009_ipCid Complete with completedAt = tx_eval_009_complete

  (_, tx_eval_009_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_009_completedCid

  let [tx_eval_009_agentReq, tx_eval_009_buyerReq] = tx_eval_009_reqs

  -- AgentPro (agent) gives feedback about BuyerEager (buyer)
  submit agentPro do
    exerciseCmd (fromInterfaceContractId tx_eval_009_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.95
        availability    = Some 0.98
        honesty         = Some 0.95
        submittedAt = tx_eval_009_feedback

  -- BuyerEager (buyer) gives feedback about AgentPro (agent)
  submit buyerEager do
    exerciseCmd (fromInterfaceContractId tx_eval_009_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.98
        availability    = Some 0.98
        honesty         = Some 1.00
        submittedAt = tx_eval_009_feedback

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-010: AgentSlowUploader (Agent) + BuyerEager (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_010_t0 = time (date 2027 Nov 23) 9 0 0
      tx_eval_010_p1_submit  = time (date 2027 Nov 23) 9 0 0
      tx_eval_010_p1_respond = time (date 2027 Nov 23) 11 0 0
      tx_eval_010_cu1          = time (date 2027 Nov 26) 19 0 0
      tx_eval_010_contract_sign   = time (date 2027 Nov 26) 23 0 0
      tx_eval_010_close    = time (date 2027 Nov 27) 0 0 0
      tx_eval_010_complete = time (date 2027 Nov 27) 1 0 0
      tx_eval_010_feedback = time (date 2027 Nov 28) 1 0 0

  tx_eval_010_draftCid <- submit agentSlowUploader do
    createCmd DraftInteraction with
      operator; initiator = agentSlowUploader; initiatorRole = Agent
      interactionId = "TX-EVAL-010"
      interactionType = "PropertyPurchase"
      participants = [(buyerEager, Buyer)]
      openedAt = tx_eval_010_t0

  tx_eval_010_ipCid <- submit agentSlowUploader do
    exerciseCmd tx_eval_010_draftCid Begin with startedAt = tx_eval_010_t0; configCid = iPPConfigCid

  tx_eval_010_ipCid <- submit operator do
    exerciseCmd tx_eval_010_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentSlowUploader; occurredAt = tx_eval_010_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_010_ipCid <- submit operator do
    exerciseCmd tx_eval_010_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerEager; occurredAt = tx_eval_010_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_010_ipCid <- submit operator do
    exerciseCmd tx_eval_010_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentSlowUploader; occurredAt = tx_eval_010_cu1
        resourceId = Some "contract-001"

  tx_eval_010_ipCid <- submit operator do
    exerciseCmd tx_eval_010_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = agentSlowUploader; occurredAt = tx_eval_010_contract_sign
        resourceId = Some "contract-001"

  tx_eval_010_ipCid <- submit operator do
    exerciseCmd tx_eval_010_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = buyerEager; occurredAt = tx_eval_010_contract_sign
        resourceId = Some "contract-001"

  tx_eval_010_ipCid <- submit operator do
    exerciseCmd tx_eval_010_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentSlowUploader; occurredAt = tx_eval_010_close
        resourceId = Some "SELL_CLOSED"

  tx_eval_010_completedCid <- submit agentSlowUploader do
    exerciseCmd tx_eval_010_ipCid Complete with completedAt = tx_eval_010_complete

  (_, tx_eval_010_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_010_completedCid

  let [tx_eval_010_agentReq, tx_eval_010_buyerReq] = tx_eval_010_reqs

  -- AgentSlowUploader (agent) gives feedback about BuyerEager (buyer)
  submit agentSlowUploader do
    exerciseCmd (fromInterfaceContractId tx_eval_010_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.90
        availability    = Some 0.95
        honesty         = Some 0.90
        submittedAt = tx_eval_010_feedback

  -- BuyerEager (buyer) gives feedback about AgentSlowUploader (agent)
  submit buyerEager do
    exerciseCmd (fromInterfaceContractId tx_eval_010_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.40
        availability    = Some 0.05
        honesty         = Some 1.00
        submittedAt = tx_eval_010_feedback

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-011: AgentHighReject (Agent) + BuyerEager (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_011_t0 = time (date 2028 Jan 22) 9 0 0
      tx_eval_011_p1_submit  = time (date 2028 Jan 22) 9 0 0
      tx_eval_011_p1_respond = time (date 2028 Jan 22) 11 0 0
      tx_eval_011_p2_submit  = time (date 2028 Jan 22) 11 0 0
      tx_eval_011_p2_respond = time (date 2028 Jan 22) 14 0 0
      tx_eval_011_p3_submit  = time (date 2028 Jan 22) 14 0 0
      tx_eval_011_p3_respond = time (date 2028 Jan 22) 16 0 0
      tx_eval_011_cu1          = time (date 2028 Jan 22) 18 0 0
      tx_eval_011_contract_sign   = time (date 2028 Jan 22) 22 0 0
      tx_eval_011_close    = time (date 2028 Jan 22) 23 0 0
      tx_eval_011_complete = time (date 2028 Jan 23) 0 0 0
      tx_eval_011_feedback = time (date 2028 Jan 24) 0 0 0

  tx_eval_011_draftCid <- submit agentHighReject do
    createCmd DraftInteraction with
      operator; initiator = agentHighReject; initiatorRole = Agent
      interactionId = "TX-EVAL-011"
      interactionType = "PropertyPurchase"
      participants = [(buyerEager, Buyer)]
      openedAt = tx_eval_011_t0

  tx_eval_011_ipCid <- submit agentHighReject do
    exerciseCmd tx_eval_011_draftCid Begin with startedAt = tx_eval_011_t0; configCid = iPPConfigCid

  tx_eval_011_ipCid <- submit operator do
    exerciseCmd tx_eval_011_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentHighReject; occurredAt = tx_eval_011_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_011_ipCid <- submit operator do
    exerciseCmd tx_eval_011_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalRejectedWithNotes; actor = buyerEager; occurredAt = tx_eval_011_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_011_ipCid <- submit operator do
    exerciseCmd tx_eval_011_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentHighReject; occurredAt = tx_eval_011_p2_submit
        resourceId = Some "proposal-002"

  tx_eval_011_ipCid <- submit operator do
    exerciseCmd tx_eval_011_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalRejectedWithNotes; actor = buyerEager; occurredAt = tx_eval_011_p2_respond
        resourceId = Some "proposal-002"

  tx_eval_011_ipCid <- submit operator do
    exerciseCmd tx_eval_011_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentHighReject; occurredAt = tx_eval_011_p3_submit
        resourceId = Some "proposal-003"

  tx_eval_011_ipCid <- submit operator do
    exerciseCmd tx_eval_011_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerEager; occurredAt = tx_eval_011_p3_respond
        resourceId = Some "proposal-003"

  tx_eval_011_ipCid <- submit operator do
    exerciseCmd tx_eval_011_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentHighReject; occurredAt = tx_eval_011_cu1
        resourceId = Some "contract-001"

  tx_eval_011_ipCid <- submit operator do
    exerciseCmd tx_eval_011_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = agentHighReject; occurredAt = tx_eval_011_contract_sign
        resourceId = Some "contract-001"

  tx_eval_011_ipCid <- submit operator do
    exerciseCmd tx_eval_011_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = buyerEager; occurredAt = tx_eval_011_contract_sign
        resourceId = Some "contract-001"

  tx_eval_011_ipCid <- submit operator do
    exerciseCmd tx_eval_011_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentHighReject; occurredAt = tx_eval_011_close
        resourceId = Some "SELL_CLOSED"

  tx_eval_011_completedCid <- submit agentHighReject do
    exerciseCmd tx_eval_011_ipCid Complete with completedAt = tx_eval_011_complete

  (_, tx_eval_011_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_011_completedCid

  let [tx_eval_011_agentReq, tx_eval_011_buyerReq] = tx_eval_011_reqs

  -- AgentHighReject (agent) gives feedback about BuyerEager (buyer)
  submit agentHighReject do
    exerciseCmd (fromInterfaceContractId tx_eval_011_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.95
        availability    = Some 0.98
        honesty         = Some 0.95
        submittedAt = tx_eval_011_feedback

  -- BuyerEager (buyer) gives feedback about AgentHighReject (agent)
  submit buyerEager do
    exerciseCmd (fromInterfaceContractId tx_eval_011_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.80
        availability    = Some 0.95
        honesty         = Some 0.35
        submittedAt = tx_eval_011_feedback

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-012: AgentUnreliable (Agent) + BuyerEager (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_012_t0 = time (date 2028 Mar 22) 9 0 0
      tx_eval_012_p1_submit  = time (date 2028 Mar 22) 9 0 0
      tx_eval_012_p1_respond = time (date 2028 Mar 22) 11 0 0
      tx_eval_012_cu1          = time (date 2028 Mar 22) 15 0 0
      tx_eval_012_close    = time (date 2028 Mar 22) 17 0 0
      tx_eval_012_complete = time (date 2028 Mar 22) 18 0 0
      tx_eval_012_feedback = time (date 2028 Mar 23) 18 0 0

  tx_eval_012_draftCid <- submit agentUnreliable do
    createCmd DraftInteraction with
      operator; initiator = agentUnreliable; initiatorRole = Agent
      interactionId = "TX-EVAL-012"
      interactionType = "PropertyPurchase"
      participants = [(buyerEager, Buyer)]
      openedAt = tx_eval_012_t0

  tx_eval_012_ipCid <- submit agentUnreliable do
    exerciseCmd tx_eval_012_draftCid Begin with startedAt = tx_eval_012_t0; configCid = iPPConfigCid

  tx_eval_012_ipCid <- submit operator do
    exerciseCmd tx_eval_012_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentUnreliable; occurredAt = tx_eval_012_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_012_ipCid <- submit operator do
    exerciseCmd tx_eval_012_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerEager; occurredAt = tx_eval_012_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_012_ipCid <- submit operator do
    exerciseCmd tx_eval_012_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentUnreliable; occurredAt = tx_eval_012_cu1
        resourceId = Some "contract-001"

  tx_eval_012_ipCid <- submit operator do
    exerciseCmd tx_eval_012_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentUnreliable; occurredAt = tx_eval_012_close
        resourceId = Some "SELL_CANCELED"

  tx_eval_012_completedCid <- submit agentUnreliable do
    exerciseCmd tx_eval_012_ipCid Complete with completedAt = tx_eval_012_complete

  (_, tx_eval_012_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_012_completedCid

  let [tx_eval_012_agentReq, tx_eval_012_buyerReq] = tx_eval_012_reqs

  -- AgentUnreliable (agent) gives feedback about BuyerEager (buyer)
  submit agentUnreliable do
    exerciseCmd (fromInterfaceContractId tx_eval_012_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.95
        availability    = Some 0.95
        honesty         = Some 1.00
        submittedAt = tx_eval_012_feedback

  -- BuyerEager (buyer) gives feedback about AgentUnreliable (agent)
  submit buyerEager do
    exerciseCmd (fromInterfaceContractId tx_eval_012_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.04
        availability    = Some 0.92
        honesty         = Some 0.95
        submittedAt = tx_eval_012_feedback

  pure ()
