-- Round 20: BuyerEager — Overseas relocation; buyer purchasing remotely and trusting the agent entirely to manage the local process.
module Scripts.EvalSeedAgentRound20 where

import Daml.Script
import DA.Time (time)
import DA.Date (date, Month(..))
import DA.Text (isPrefixOf)

import Reputation.PropertyPurchase.Configuration (PropertyPurchaseConfiguration(..))
import Reputation.PropertyPurchase.Configuration qualified as PP
import Reputation.Interaction.Draft (DraftInteraction(..), Begin(..))
import Reputation.Interaction.InProgress (RecordEvent(..), Complete(..))
import Reputation.Interface.Configuration qualified as Configuration (I)
import Reputation.Types
import Reputation.PropertyPurchase.Feedback (PropertyPurchaseFeedbackRequest, SubmitFeedback(..))

evalSeedAgentRound20 : Script ()
evalSeedAgentRound20 = do

  -- ── Look up parties ───────────────────────────────────────────────
  knownParties <- listKnownParties
  let lookupParty name = case find (\pd -> (name <> "::") `isPrefixOf` (partyToText pd.party)) knownParties of
        None -> fail $ "Party not found: " <> name
        Some pd -> pure pd.party

  operator         <- case find (\pd -> "Operator::" `isPrefixOf` (partyToText pd.party)) knownParties of
    None -> fail "Operator party not found."
    Some pd -> pure pd.party
  agentHighReject    <- lookupParty "AgentHighReject"
  agentPro           <- lookupParty "AgentPro"
  agentSlowUploader  <- lookupParty "AgentSlowUploader"
  agentUnreliable    <- lookupParty "AgentUnreliable"
  buyerEager         <- lookupParty "BuyerEager"

  -- ── Look up PP config ─────────────────────────────────────────────
  ppConfigs <- query @PropertyPurchaseConfiguration operator
  ppConfigCid <- case find (\(_, c) -> c.configId == "EVAL-PP-CONFIG") ppConfigs of
    None -> fail "PropertyPurchaseConfiguration 'EVAL-PP-CONFIG' not found. Run EvalSeedAgentSetup first."
    Some (cid, _) -> pure cid
  let iPPConfigCid : ContractId Configuration.I = toInterfaceContractId ppConfigCid

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-077: AgentPro (Agent) + BuyerEager (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_077_t0 = time (date 2038 Nov 25) 9 0 0
      tx_eval_077_p1_submit  = time (date 2038 Nov 25) 9 0 0
      tx_eval_077_p1_respond = time (date 2038 Nov 25) 11 0 0
      tx_eval_077_cu1          = time (date 2038 Nov 25) 14 0 0
      tx_eval_077_contract_sign   = time (date 2038 Nov 25) 18 0 0
      tx_eval_077_close    = time (date 2038 Nov 25) 19 0 0
      tx_eval_077_complete = time (date 2038 Nov 25) 20 0 0
      tx_eval_077_feedback = time (date 2038 Nov 26) 20 0 0

  tx_eval_077_draftCid <- submit agentPro do
    createCmd DraftInteraction with
      operator; initiator = agentPro; initiatorRole = Agent
      interactionId = "TX-EVAL-077"
      interactionType = "PropertyPurchase"
      participants = [(buyerEager, Buyer)]
      openedAt = tx_eval_077_t0

  tx_eval_077_ipCid <- submit agentPro do
    exerciseCmd tx_eval_077_draftCid Begin with startedAt = tx_eval_077_t0; configCid = iPPConfigCid

  tx_eval_077_ipCid <- submit operator do
    exerciseCmd tx_eval_077_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentPro; occurredAt = tx_eval_077_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_077_ipCid <- submit operator do
    exerciseCmd tx_eval_077_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerEager; occurredAt = tx_eval_077_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_077_ipCid <- submit operator do
    exerciseCmd tx_eval_077_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentPro; occurredAt = tx_eval_077_cu1
        resourceId = Some "contract-001"

  tx_eval_077_ipCid <- submit operator do
    exerciseCmd tx_eval_077_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = agentPro; occurredAt = tx_eval_077_contract_sign
        resourceId = Some "contract-001"

  tx_eval_077_ipCid <- submit operator do
    exerciseCmd tx_eval_077_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = buyerEager; occurredAt = tx_eval_077_contract_sign
        resourceId = Some "contract-001"

  tx_eval_077_ipCid <- submit operator do
    exerciseCmd tx_eval_077_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentPro; occurredAt = tx_eval_077_close
        resourceId = Some "SELL_CLOSED"

  tx_eval_077_completedCid <- submit agentPro do
    exerciseCmd tx_eval_077_ipCid Complete with completedAt = tx_eval_077_complete

  (_, tx_eval_077_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_077_completedCid

  let [tx_eval_077_agentReq, tx_eval_077_buyerReq] = tx_eval_077_reqs

  -- AgentPro (agent) gives feedback about BuyerEager (buyer)
  submit agentPro do
    exerciseCmd (fromInterfaceContractId tx_eval_077_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.95
        availability    = Some 0.98
        honesty         = Some 0.95
        submittedAt = tx_eval_077_feedback

  -- BuyerEager (buyer) gives feedback about AgentPro (agent)
  submit buyerEager do
    exerciseCmd (fromInterfaceContractId tx_eval_077_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.98
        availability    = Some 0.97
        honesty         = Some 0.98
        submittedAt = tx_eval_077_feedback

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-078: AgentSlowUploader (Agent) + BuyerEager (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_078_t0 = time (date 2039 Jan 24) 9 0 0
      tx_eval_078_p1_submit  = time (date 2039 Jan 24) 9 0 0
      tx_eval_078_p1_respond = time (date 2039 Jan 24) 11 0 0
      tx_eval_078_cu1          = time (date 2039 Jan 27) 19 0 0
      tx_eval_078_contract_sign   = time (date 2039 Jan 27) 23 0 0
      tx_eval_078_close    = time (date 2039 Jan 28) 0 0 0
      tx_eval_078_complete = time (date 2039 Jan 28) 1 0 0
      tx_eval_078_feedback = time (date 2039 Jan 29) 1 0 0

  tx_eval_078_draftCid <- submit agentSlowUploader do
    createCmd DraftInteraction with
      operator; initiator = agentSlowUploader; initiatorRole = Agent
      interactionId = "TX-EVAL-078"
      interactionType = "PropertyPurchase"
      participants = [(buyerEager, Buyer)]
      openedAt = tx_eval_078_t0

  tx_eval_078_ipCid <- submit agentSlowUploader do
    exerciseCmd tx_eval_078_draftCid Begin with startedAt = tx_eval_078_t0; configCid = iPPConfigCid

  tx_eval_078_ipCid <- submit operator do
    exerciseCmd tx_eval_078_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentSlowUploader; occurredAt = tx_eval_078_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_078_ipCid <- submit operator do
    exerciseCmd tx_eval_078_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerEager; occurredAt = tx_eval_078_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_078_ipCid <- submit operator do
    exerciseCmd tx_eval_078_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentSlowUploader; occurredAt = tx_eval_078_cu1
        resourceId = Some "contract-001"

  tx_eval_078_ipCid <- submit operator do
    exerciseCmd tx_eval_078_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = agentSlowUploader; occurredAt = tx_eval_078_contract_sign
        resourceId = Some "contract-001"

  tx_eval_078_ipCid <- submit operator do
    exerciseCmd tx_eval_078_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = buyerEager; occurredAt = tx_eval_078_contract_sign
        resourceId = Some "contract-001"

  tx_eval_078_ipCid <- submit operator do
    exerciseCmd tx_eval_078_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentSlowUploader; occurredAt = tx_eval_078_close
        resourceId = Some "SELL_CLOSED"

  tx_eval_078_completedCid <- submit agentSlowUploader do
    exerciseCmd tx_eval_078_ipCid Complete with completedAt = tx_eval_078_complete

  (_, tx_eval_078_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_078_completedCid

  let [tx_eval_078_agentReq, tx_eval_078_buyerReq] = tx_eval_078_reqs

  -- AgentSlowUploader (agent) gives feedback about BuyerEager (buyer)
  submit agentSlowUploader do
    exerciseCmd (fromInterfaceContractId tx_eval_078_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.85
        availability    = Some 0.95
        honesty         = Some 0.90
        submittedAt = tx_eval_078_feedback

  -- BuyerEager (buyer) gives feedback about AgentSlowUploader (agent)
  submit buyerEager do
    exerciseCmd (fromInterfaceContractId tx_eval_078_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.45
        availability    = Some 0.10
        honesty         = Some 1.00
        submittedAt = tx_eval_078_feedback

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-079: AgentHighReject (Agent) + BuyerEager (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_079_t0 = time (date 2039 Mar 25) 9 0 0
      tx_eval_079_p1_submit  = time (date 2039 Mar 25) 9 0 0
      tx_eval_079_p1_respond = time (date 2039 Mar 25) 11 0 0
      tx_eval_079_p2_submit  = time (date 2039 Mar 25) 11 0 0
      tx_eval_079_p2_respond = time (date 2039 Mar 25) 13 0 0
      tx_eval_079_p3_submit  = time (date 2039 Mar 25) 13 0 0
      tx_eval_079_p3_respond = time (date 2039 Mar 25) 16 0 0
      tx_eval_079_cu1          = time (date 2039 Mar 25) 18 0 0
      tx_eval_079_contract_sign   = time (date 2039 Mar 25) 22 0 0
      tx_eval_079_close    = time (date 2039 Mar 25) 23 0 0
      tx_eval_079_complete = time (date 2039 Mar 26) 0 0 0
      tx_eval_079_feedback = time (date 2039 Mar 27) 0 0 0

  tx_eval_079_draftCid <- submit agentHighReject do
    createCmd DraftInteraction with
      operator; initiator = agentHighReject; initiatorRole = Agent
      interactionId = "TX-EVAL-079"
      interactionType = "PropertyPurchase"
      participants = [(buyerEager, Buyer)]
      openedAt = tx_eval_079_t0

  tx_eval_079_ipCid <- submit agentHighReject do
    exerciseCmd tx_eval_079_draftCid Begin with startedAt = tx_eval_079_t0; configCid = iPPConfigCid

  tx_eval_079_ipCid <- submit operator do
    exerciseCmd tx_eval_079_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentHighReject; occurredAt = tx_eval_079_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_079_ipCid <- submit operator do
    exerciseCmd tx_eval_079_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalRejectedWithNotes; actor = buyerEager; occurredAt = tx_eval_079_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_079_ipCid <- submit operator do
    exerciseCmd tx_eval_079_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentHighReject; occurredAt = tx_eval_079_p2_submit
        resourceId = Some "proposal-002"

  tx_eval_079_ipCid <- submit operator do
    exerciseCmd tx_eval_079_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalRejectedWithNotes; actor = buyerEager; occurredAt = tx_eval_079_p2_respond
        resourceId = Some "proposal-002"

  tx_eval_079_ipCid <- submit operator do
    exerciseCmd tx_eval_079_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentHighReject; occurredAt = tx_eval_079_p3_submit
        resourceId = Some "proposal-003"

  tx_eval_079_ipCid <- submit operator do
    exerciseCmd tx_eval_079_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerEager; occurredAt = tx_eval_079_p3_respond
        resourceId = Some "proposal-003"

  tx_eval_079_ipCid <- submit operator do
    exerciseCmd tx_eval_079_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentHighReject; occurredAt = tx_eval_079_cu1
        resourceId = Some "contract-001"

  tx_eval_079_ipCid <- submit operator do
    exerciseCmd tx_eval_079_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = agentHighReject; occurredAt = tx_eval_079_contract_sign
        resourceId = Some "contract-001"

  tx_eval_079_ipCid <- submit operator do
    exerciseCmd tx_eval_079_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = buyerEager; occurredAt = tx_eval_079_contract_sign
        resourceId = Some "contract-001"

  tx_eval_079_ipCid <- submit operator do
    exerciseCmd tx_eval_079_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentHighReject; occurredAt = tx_eval_079_close
        resourceId = Some "SELL_CLOSED"

  tx_eval_079_completedCid <- submit agentHighReject do
    exerciseCmd tx_eval_079_ipCid Complete with completedAt = tx_eval_079_complete

  (_, tx_eval_079_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_079_completedCid

  let [tx_eval_079_agentReq, tx_eval_079_buyerReq] = tx_eval_079_reqs

  -- AgentHighReject (agent) gives feedback about BuyerEager (buyer)
  submit agentHighReject do
    exerciseCmd (fromInterfaceContractId tx_eval_079_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.95
        availability    = Some 0.98
        honesty         = Some 0.95
        submittedAt = tx_eval_079_feedback

  -- BuyerEager (buyer) gives feedback about AgentHighReject (agent)
  submit buyerEager do
    exerciseCmd (fromInterfaceContractId tx_eval_079_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.80
        availability    = Some 0.95
        honesty         = Some 0.35
        submittedAt = tx_eval_079_feedback

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-080: AgentUnreliable (Agent) + BuyerEager (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_080_t0 = time (date 2039 May 24) 9 0 0
      tx_eval_080_p1_submit  = time (date 2039 May 24) 9 0 0
      tx_eval_080_p1_respond = time (date 2039 May 24) 11 0 0
      tx_eval_080_cu1          = time (date 2039 May 24) 15 0 0
      tx_eval_080_close    = time (date 2039 May 24) 17 0 0
      tx_eval_080_complete = time (date 2039 May 24) 18 0 0
      tx_eval_080_feedback = time (date 2039 May 25) 18 0 0

  tx_eval_080_draftCid <- submit agentUnreliable do
    createCmd DraftInteraction with
      operator; initiator = agentUnreliable; initiatorRole = Agent
      interactionId = "TX-EVAL-080"
      interactionType = "PropertyPurchase"
      participants = [(buyerEager, Buyer)]
      openedAt = tx_eval_080_t0

  tx_eval_080_ipCid <- submit agentUnreliable do
    exerciseCmd tx_eval_080_draftCid Begin with startedAt = tx_eval_080_t0; configCid = iPPConfigCid

  tx_eval_080_ipCid <- submit operator do
    exerciseCmd tx_eval_080_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentUnreliable; occurredAt = tx_eval_080_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_080_ipCid <- submit operator do
    exerciseCmd tx_eval_080_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerEager; occurredAt = tx_eval_080_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_080_ipCid <- submit operator do
    exerciseCmd tx_eval_080_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentUnreliable; occurredAt = tx_eval_080_cu1
        resourceId = Some "contract-001"

  tx_eval_080_ipCid <- submit operator do
    exerciseCmd tx_eval_080_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentUnreliable; occurredAt = tx_eval_080_close
        resourceId = Some "SELL_CANCELED"

  tx_eval_080_completedCid <- submit agentUnreliable do
    exerciseCmd tx_eval_080_ipCid Complete with completedAt = tx_eval_080_complete

  (_, tx_eval_080_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_080_completedCid

  let [tx_eval_080_agentReq, tx_eval_080_buyerReq] = tx_eval_080_reqs

  -- AgentUnreliable (agent) gives feedback about BuyerEager (buyer)
  submit agentUnreliable do
    exerciseCmd (fromInterfaceContractId tx_eval_080_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.95
        availability    = Some 0.98
        honesty         = Some 0.95
        submittedAt = tx_eval_080_feedback

  -- BuyerEager (buyer) gives feedback about AgentUnreliable (agent)
  submit buyerEager do
    exerciseCmd (fromInterfaceContractId tx_eval_080_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.03
        availability    = Some 0.92
        honesty         = Some 0.95
        submittedAt = tx_eval_080_feedback

  pure ()
