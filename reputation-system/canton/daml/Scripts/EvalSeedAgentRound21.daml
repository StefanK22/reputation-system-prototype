-- Round 21: BuyerPersistent — Slow market; property has been listed for six months and buyer knows they have negotiating leverage.
module Scripts.EvalSeedAgentRound21 where

import Daml.Script
import DA.Time (time)
import DA.Date (date, Month(..))
import DA.Text (isPrefixOf)

import Reputation.PropertyPurchase.Configuration (PropertyPurchaseConfiguration(..))
import Reputation.PropertyPurchase.Configuration qualified as PP
import Reputation.Interaction.Draft (DraftInteraction(..), Begin(..))
import Reputation.Interaction.InProgress (RecordEvent(..), Complete(..))
import Reputation.Interface.Configuration qualified as Configuration (I)
import Reputation.Types
import Reputation.PropertyPurchase.Feedback (PropertyPurchaseFeedbackRequest, SubmitFeedback(..))

evalSeedAgentRound21 : Script ()
evalSeedAgentRound21 = do

  -- ── Look up parties ───────────────────────────────────────────────
  knownParties <- listKnownParties
  let lookupParty name = case find (\pd -> (name <> "::") `isPrefixOf` (partyToText pd.party)) knownParties of
        None -> fail $ "Party not found: " <> name
        Some pd -> pure pd.party

  operator         <- case find (\pd -> "Operator::" `isPrefixOf` (partyToText pd.party)) knownParties of
    None -> fail "Operator party not found."
    Some pd -> pure pd.party
  agentHighReject    <- lookupParty "AgentHighReject"
  agentPro           <- lookupParty "AgentPro"
  agentSlowUploader  <- lookupParty "AgentSlowUploader"
  agentUnreliable    <- lookupParty "AgentUnreliable"
  buyerPersistent    <- lookupParty "BuyerPersistent"

  -- ── Look up PP config ─────────────────────────────────────────────
  ppConfigs <- query @PropertyPurchaseConfiguration operator
  ppConfigCid <- case find (\(_, c) -> c.configId == "EVAL-PP-CONFIG") ppConfigs of
    None -> fail "PropertyPurchaseConfiguration 'EVAL-PP-CONFIG' not found. Run EvalSeedAgentSetup first."
    Some (cid, _) -> pure cid
  let iPPConfigCid : ContractId Configuration.I = toInterfaceContractId ppConfigCid

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-081: AgentPro (Agent) + BuyerPersistent (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_081_t0 = time (date 2039 Jul 23) 9 0 0
      tx_eval_081_p1_submit  = time (date 2039 Jul 23) 9 0 0
      tx_eval_081_p1_respond = time (date 2039 Jul 24) 21 0 0
      tx_eval_081_p2_submit  = time (date 2039 Jul 24) 21 0 0
      tx_eval_081_p2_respond = time (date 2039 Jul 25) 21 0 0
      tx_eval_081_cu1          = time (date 2039 Jul 26) 1 0 0
      tx_eval_081_contract_sign   = time (date 2039 Jul 28) 1 0 0
      tx_eval_081_close    = time (date 2039 Jul 28) 2 0 0
      tx_eval_081_complete = time (date 2039 Jul 28) 3 0 0
      tx_eval_081_feedback = time (date 2039 Jul 29) 3 0 0

  tx_eval_081_draftCid <- submit agentPro do
    createCmd DraftInteraction with
      operator; initiator = agentPro; initiatorRole = Agent
      interactionId = "TX-EVAL-081"
      interactionType = "PropertyPurchase"
      participants = [(buyerPersistent, Buyer)]
      openedAt = tx_eval_081_t0

  tx_eval_081_ipCid <- submit agentPro do
    exerciseCmd tx_eval_081_draftCid Begin with startedAt = tx_eval_081_t0; configCid = iPPConfigCid

  tx_eval_081_ipCid <- submit operator do
    exerciseCmd tx_eval_081_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentPro; occurredAt = tx_eval_081_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_081_ipCid <- submit operator do
    exerciseCmd tx_eval_081_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalRejectedWithNotes; actor = buyerPersistent; occurredAt = tx_eval_081_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_081_ipCid <- submit operator do
    exerciseCmd tx_eval_081_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentPro; occurredAt = tx_eval_081_p2_submit
        resourceId = Some "proposal-002"

  tx_eval_081_ipCid <- submit operator do
    exerciseCmd tx_eval_081_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerPersistent; occurredAt = tx_eval_081_p2_respond
        resourceId = Some "proposal-002"

  tx_eval_081_ipCid <- submit operator do
    exerciseCmd tx_eval_081_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentPro; occurredAt = tx_eval_081_cu1
        resourceId = Some "contract-001"

  tx_eval_081_ipCid <- submit operator do
    exerciseCmd tx_eval_081_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = agentPro; occurredAt = tx_eval_081_contract_sign
        resourceId = Some "contract-001"

  tx_eval_081_ipCid <- submit operator do
    exerciseCmd tx_eval_081_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = buyerPersistent; occurredAt = tx_eval_081_contract_sign
        resourceId = Some "contract-001"

  tx_eval_081_ipCid <- submit operator do
    exerciseCmd tx_eval_081_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentPro; occurredAt = tx_eval_081_close
        resourceId = Some "SELL_CLOSED"

  tx_eval_081_completedCid <- submit agentPro do
    exerciseCmd tx_eval_081_ipCid Complete with completedAt = tx_eval_081_complete

  (_, tx_eval_081_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_081_completedCid

  let [tx_eval_081_agentReq, tx_eval_081_buyerReq] = tx_eval_081_reqs

  -- AgentPro (agent) gives feedback about BuyerPersistent (buyer)
  submit agentPro do
    exerciseCmd (fromInterfaceContractId tx_eval_081_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.90
        availability    = Some 0.45
        honesty         = Some 0.95
        submittedAt = tx_eval_081_feedback

  -- BuyerPersistent (buyer) gives feedback about AgentPro (agent)
  submit buyerPersistent do
    exerciseCmd (fromInterfaceContractId tx_eval_081_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.98
        availability    = Some 0.96
        honesty         = Some 0.70
        submittedAt = tx_eval_081_feedback

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-082: AgentSlowUploader (Agent) + BuyerPersistent (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_082_t0 = time (date 2039 Sep 21) 9 0 0
      tx_eval_082_p1_submit  = time (date 2039 Sep 21) 9 0 0
      tx_eval_082_p1_respond = time (date 2039 Sep 22) 17 0 0
      tx_eval_082_p2_submit  = time (date 2039 Sep 22) 17 0 0
      tx_eval_082_p2_respond = time (date 2039 Sep 23) 17 0 0
      tx_eval_082_cu1          = time (date 2039 Sep 27) 5 0 0
      tx_eval_082_contract_sign   = time (date 2039 Sep 28) 17 0 0
      tx_eval_082_close    = time (date 2039 Sep 28) 18 0 0
      tx_eval_082_complete = time (date 2039 Sep 28) 19 0 0
      tx_eval_082_feedback = time (date 2039 Sep 29) 19 0 0

  tx_eval_082_draftCid <- submit agentSlowUploader do
    createCmd DraftInteraction with
      operator; initiator = agentSlowUploader; initiatorRole = Agent
      interactionId = "TX-EVAL-082"
      interactionType = "PropertyPurchase"
      participants = [(buyerPersistent, Buyer)]
      openedAt = tx_eval_082_t0

  tx_eval_082_ipCid <- submit agentSlowUploader do
    exerciseCmd tx_eval_082_draftCid Begin with startedAt = tx_eval_082_t0; configCid = iPPConfigCid

  tx_eval_082_ipCid <- submit operator do
    exerciseCmd tx_eval_082_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentSlowUploader; occurredAt = tx_eval_082_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_082_ipCid <- submit operator do
    exerciseCmd tx_eval_082_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalRejectedWithNotes; actor = buyerPersistent; occurredAt = tx_eval_082_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_082_ipCid <- submit operator do
    exerciseCmd tx_eval_082_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentSlowUploader; occurredAt = tx_eval_082_p2_submit
        resourceId = Some "proposal-002"

  tx_eval_082_ipCid <- submit operator do
    exerciseCmd tx_eval_082_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerPersistent; occurredAt = tx_eval_082_p2_respond
        resourceId = Some "proposal-002"

  tx_eval_082_ipCid <- submit operator do
    exerciseCmd tx_eval_082_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentSlowUploader; occurredAt = tx_eval_082_cu1
        resourceId = Some "contract-001"

  tx_eval_082_ipCid <- submit operator do
    exerciseCmd tx_eval_082_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = agentSlowUploader; occurredAt = tx_eval_082_contract_sign
        resourceId = Some "contract-001"

  tx_eval_082_ipCid <- submit operator do
    exerciseCmd tx_eval_082_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = buyerPersistent; occurredAt = tx_eval_082_contract_sign
        resourceId = Some "contract-001"

  tx_eval_082_ipCid <- submit operator do
    exerciseCmd tx_eval_082_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentSlowUploader; occurredAt = tx_eval_082_close
        resourceId = Some "SELL_CLOSED"

  tx_eval_082_completedCid <- submit agentSlowUploader do
    exerciseCmd tx_eval_082_ipCid Complete with completedAt = tx_eval_082_complete

  (_, tx_eval_082_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_082_completedCid

  let [tx_eval_082_agentReq, tx_eval_082_buyerReq] = tx_eval_082_reqs

  -- AgentSlowUploader (agent) gives feedback about BuyerPersistent (buyer)
  submit agentSlowUploader do
    exerciseCmd (fromInterfaceContractId tx_eval_082_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.80
        availability    = Some 0.45
        honesty         = Some 0.85
        submittedAt = tx_eval_082_feedback

  -- BuyerPersistent (buyer) gives feedback about AgentSlowUploader (agent)
  submit buyerPersistent do
    exerciseCmd (fromInterfaceContractId tx_eval_082_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.50
        availability    = Some 0.12
        honesty         = Some 0.65
        submittedAt = tx_eval_082_feedback

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-083: AgentHighReject (Agent) + BuyerPersistent (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_083_t0 = time (date 2039 Nov 20) 9 0 0
      tx_eval_083_p1_submit  = time (date 2039 Nov 20) 9 0 0
      tx_eval_083_p1_respond = time (date 2039 Nov 21) 3 0 0
      tx_eval_083_p2_submit  = time (date 2039 Nov 21) 3 0 0
      tx_eval_083_p2_respond = time (date 2039 Nov 22) 3 0 0
      tx_eval_083_p3_submit  = time (date 2039 Nov 22) 3 0 0
      tx_eval_083_p3_respond = time (date 2039 Nov 22) 23 0 0
      tx_eval_083_cu1          = time (date 2039 Nov 23) 1 0 0
      tx_eval_083_contract_sign   = time (date 2039 Nov 23) 13 0 0
      tx_eval_083_close    = time (date 2039 Nov 23) 14 0 0
      tx_eval_083_complete = time (date 2039 Nov 23) 15 0 0
      tx_eval_083_feedback = time (date 2039 Nov 24) 15 0 0

  tx_eval_083_draftCid <- submit agentHighReject do
    createCmd DraftInteraction with
      operator; initiator = agentHighReject; initiatorRole = Agent
      interactionId = "TX-EVAL-083"
      interactionType = "PropertyPurchase"
      participants = [(buyerPersistent, Buyer)]
      openedAt = tx_eval_083_t0

  tx_eval_083_ipCid <- submit agentHighReject do
    exerciseCmd tx_eval_083_draftCid Begin with startedAt = tx_eval_083_t0; configCid = iPPConfigCid

  tx_eval_083_ipCid <- submit operator do
    exerciseCmd tx_eval_083_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentHighReject; occurredAt = tx_eval_083_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_083_ipCid <- submit operator do
    exerciseCmd tx_eval_083_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalRejectedWithNotes; actor = buyerPersistent; occurredAt = tx_eval_083_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_083_ipCid <- submit operator do
    exerciseCmd tx_eval_083_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentHighReject; occurredAt = tx_eval_083_p2_submit
        resourceId = Some "proposal-002"

  tx_eval_083_ipCid <- submit operator do
    exerciseCmd tx_eval_083_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalRejectedWithNotes; actor = buyerPersistent; occurredAt = tx_eval_083_p2_respond
        resourceId = Some "proposal-002"

  tx_eval_083_ipCid <- submit operator do
    exerciseCmd tx_eval_083_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentHighReject; occurredAt = tx_eval_083_p3_submit
        resourceId = Some "proposal-003"

  tx_eval_083_ipCid <- submit operator do
    exerciseCmd tx_eval_083_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerPersistent; occurredAt = tx_eval_083_p3_respond
        resourceId = Some "proposal-003"

  tx_eval_083_ipCid <- submit operator do
    exerciseCmd tx_eval_083_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentHighReject; occurredAt = tx_eval_083_cu1
        resourceId = Some "contract-001"

  tx_eval_083_ipCid <- submit operator do
    exerciseCmd tx_eval_083_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = agentHighReject; occurredAt = tx_eval_083_contract_sign
        resourceId = Some "contract-001"

  tx_eval_083_ipCid <- submit operator do
    exerciseCmd tx_eval_083_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractSigned; actor = buyerPersistent; occurredAt = tx_eval_083_contract_sign
        resourceId = Some "contract-001"

  tx_eval_083_ipCid <- submit operator do
    exerciseCmd tx_eval_083_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentHighReject; occurredAt = tx_eval_083_close
        resourceId = Some "SELL_CLOSED"

  tx_eval_083_completedCid <- submit agentHighReject do
    exerciseCmd tx_eval_083_ipCid Complete with completedAt = tx_eval_083_complete

  (_, tx_eval_083_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_083_completedCid

  let [tx_eval_083_agentReq, tx_eval_083_buyerReq] = tx_eval_083_reqs

  -- AgentHighReject (agent) gives feedback about BuyerPersistent (buyer)
  submit agentHighReject do
    exerciseCmd (fromInterfaceContractId tx_eval_083_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.95
        availability    = Some 0.55
        honesty         = Some 0.95
        submittedAt = tx_eval_083_feedback

  -- BuyerPersistent (buyer) gives feedback about AgentHighReject (agent)
  submit buyerPersistent do
    exerciseCmd (fromInterfaceContractId tx_eval_083_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.75
        availability    = Some 0.95
        honesty         = Some 0.35
        submittedAt = tx_eval_083_feedback

  -- ═══════════════════════════════════════════════════════════
  -- TX-EVAL-084: AgentUnreliable (Agent) + BuyerPersistent (Buyer)
  -- ═══════════════════════════════════════════════════════════
  let tx_eval_084_t0 = time (date 2040 Jan 19) 9 0 0
      tx_eval_084_p1_submit  = time (date 2040 Jan 19) 9 0 0
      tx_eval_084_p1_respond = time (date 2040 Jan 20) 21 0 0
      tx_eval_084_p2_submit  = time (date 2040 Jan 20) 21 0 0
      tx_eval_084_p2_respond = time (date 2040 Jan 22) 1 0 0
      tx_eval_084_p3_submit  = time (date 2040 Jan 22) 1 0 0
      tx_eval_084_p3_respond = time (date 2040 Jan 23) 1 0 0
      tx_eval_084_cu1          = time (date 2040 Jan 23) 5 0 0
      tx_eval_084_close    = time (date 2040 Jan 23) 7 0 0
      tx_eval_084_complete = time (date 2040 Jan 23) 8 0 0
      tx_eval_084_feedback = time (date 2040 Jan 24) 8 0 0

  tx_eval_084_draftCid <- submit agentUnreliable do
    createCmd DraftInteraction with
      operator; initiator = agentUnreliable; initiatorRole = Agent
      interactionId = "TX-EVAL-084"
      interactionType = "PropertyPurchase"
      participants = [(buyerPersistent, Buyer)]
      openedAt = tx_eval_084_t0

  tx_eval_084_ipCid <- submit agentUnreliable do
    exerciseCmd tx_eval_084_draftCid Begin with startedAt = tx_eval_084_t0; configCid = iPPConfigCid

  tx_eval_084_ipCid <- submit operator do
    exerciseCmd tx_eval_084_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentUnreliable; occurredAt = tx_eval_084_p1_submit
        resourceId = Some "proposal-001"

  tx_eval_084_ipCid <- submit operator do
    exerciseCmd tx_eval_084_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalRejectedWithNotes; actor = buyerPersistent; occurredAt = tx_eval_084_p1_respond
        resourceId = Some "proposal-001"

  tx_eval_084_ipCid <- submit operator do
    exerciseCmd tx_eval_084_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentUnreliable; occurredAt = tx_eval_084_p2_submit
        resourceId = Some "proposal-002"

  tx_eval_084_ipCid <- submit operator do
    exerciseCmd tx_eval_084_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalRejectedWithNotes; actor = buyerPersistent; occurredAt = tx_eval_084_p2_respond
        resourceId = Some "proposal-002"

  tx_eval_084_ipCid <- submit operator do
    exerciseCmd tx_eval_084_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalSubmitted; actor = agentUnreliable; occurredAt = tx_eval_084_p3_submit
        resourceId = Some "proposal-003"

  tx_eval_084_ipCid <- submit operator do
    exerciseCmd tx_eval_084_ipCid RecordEvent with
      event = RecordedEvent with
        event = ProposalApproved; actor = buyerPersistent; occurredAt = tx_eval_084_p3_respond
        resourceId = Some "proposal-003"

  tx_eval_084_ipCid <- submit operator do
    exerciseCmd tx_eval_084_ipCid RecordEvent with
      event = RecordedEvent with
        event = ContractUploaded; actor = agentUnreliable; occurredAt = tx_eval_084_cu1
        resourceId = Some "contract-001"

  tx_eval_084_ipCid <- submit operator do
    exerciseCmd tx_eval_084_ipCid RecordEvent with
      event = RecordedEvent with
        event = TransactionStateChanged; actor = agentUnreliable; occurredAt = tx_eval_084_close
        resourceId = Some "SELL_CANCELED"

  tx_eval_084_completedCid <- submit agentUnreliable do
    exerciseCmd tx_eval_084_ipCid Complete with completedAt = tx_eval_084_complete

  (_, tx_eval_084_reqs) <- submit operator do
    exerciseCmd ppConfigCid PP.CreateObservations with completedCid = tx_eval_084_completedCid

  let [tx_eval_084_agentReq, tx_eval_084_buyerReq] = tx_eval_084_reqs

  -- AgentUnreliable (agent) gives feedback about BuyerPersistent (buyer)
  submit agentUnreliable do
    exerciseCmd (fromInterfaceContractId tx_eval_084_agentReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.90
        availability    = Some 0.30
        honesty         = Some 0.95
        submittedAt = tx_eval_084_feedback

  -- BuyerPersistent (buyer) gives feedback about AgentUnreliable (agent)
  submit buyerPersistent do
    exerciseCmd (fromInterfaceContractId tx_eval_084_buyerReq : ContractId PropertyPurchaseFeedbackRequest)
      SubmitFeedback with
        professionalism = Some 0.03
        availability    = Some 0.95
        honesty         = Some 0.35
        submittedAt = tx_eval_084_feedback

  pure ()
