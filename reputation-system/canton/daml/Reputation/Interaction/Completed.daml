module Reputation.Interaction.Completed where

import Reputation.Interface.Configuration qualified as Configuration (I)
import Reputation.Interface.Interaction qualified as Interaction (I, View(..))
import Reputation.Types (RecordedEvent, RoleType)

template CompletedInteraction
    with
        operator        : Party 
        initiator       : Party
        interactionId   : Text
        interactionType : Text
        participants    : [(Party, RoleType)]
        events          : [RecordedEvent]
        startedAt       : Time
        completedAt     : Time
        configCid       : ContractId Configuration.I
        processed       : Bool
    where
        signatory initiator
        observer map fst participants

        ensure
            interactionId /= "" 
                && not (null participants)
                && completedAt >= startedAt
        
        interface instance Interaction.I for CompletedInteraction where
            view = Interaction.View with
                operator 
                initiator
                interactionId
                interactionType
                participants
                events
                configCid
                processed
        
        choice ProcessInteraction : ContractId CompletedInteraction 
            controller operator
            do
                create this with
                    processed = True