module Reputation.PropertyPurchase.AgentObservation where

import Reputation.Interface.Observation qualified as Observation (I, View(..))
import Reputation.Interface.Configuration qualified as Configuration (I)
import Reputation.PropertyPurchase.Types (AgentObservationWeights)
import Reputation.Types (ComponentId(..))
import Reputation.Utils (normalize, mean)
import DA.Map qualified as Map

computeReliability : Bool -> Int -> AgentObservationWeights -> Decimal
computeReliability transactionCompleted contractVoided w =
    let
        completionScore = if transactionCompleted then 1.0 else 0.0
        voidedScore     = 1.0 / (1.0 + intToDecimal contractVoided)
    in
        w.reliabilityCompletionWeight * completionScore +
        w.reliabilityVoidedWeight * voidedScore

computeResponsiveness : Optional Int -> [Int] -> AgentObservationWeights -> Optional Decimal
computeResponsiveness None [] _ = None
computeResponsiveness proposalToCTime contractTimes w =
    let
        optionalScore = case proposalToCTime of
            None   -> 0.0
            Some t -> w.responsivenessProposalToContractWeight * normalize w.responsivenessCapHours (intToDecimal t)
        contractScore = w.responsivenessContractWeight * normalize w.responsivenessCapHours (mean contractTimes)
    in
        Some (optionalScore + contractScore)


computeAccuracy : Int -> Int -> Optional Decimal
computeAccuracy 0 0 = None
computeAccuracy approved rejected =
    let
        total = intToDecimal (approved + rejected)
    in
        Some (intToDecimal approved / total)



template AgentObservation
    with
        operator                : Party
        interactionId           : Text
        subject                 : Party
        -- Reliability
        transactionCompleted    : Bool
        contractVoided          : Int
        -- Responsiveness
        proposalToContractTime  : Optional Int
        contractSigningTimes    : [Int]
        -- Accuracy
        proposalApprovedCount   : Int
        proposalRejectedCount   : Int
        -- Weights
        agentObsWeights         : AgentObservationWeights
        configCid               : ContractId Configuration.I
        recordedAt              : Time
        processed               : Bool
    where
        signatory operator
        observer subject

        ensure interactionId /= ""

        interface instance Observation.I for AgentObservation where
            view = Observation.View with
                operator
                interactionId
                subject
                recordedAt
                componentValues = Map.fromList
                    [(Reliability, Some (computeReliability
                        transactionCompleted
                        contractVoided
                        agentObsWeights)
                    ),
                    (Responsiveness, computeResponsiveness
                        proposalToContractTime
                        contractSigningTimes
                        agentObsWeights
                    ),
                    (Accuracy, computeAccuracy
                        proposalApprovedCount
                        proposalRejectedCount
                    )]
                processed
                configCid
            setProcessed = toInterfaceContractId <$>
                create this with processed = True
