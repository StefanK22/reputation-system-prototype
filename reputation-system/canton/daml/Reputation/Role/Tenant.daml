module Reputation.Role.Tenant where

import DA.Map qualified as Map
import Reputation.Interface.Role qualified as Role (I, View(..))
import Reputation.Interface.Configuration qualified as Configuration (I)
import Reputation.Types (ComponentId(..))

template TenantRole
    with
        operator        : Party 
        party           : Party
        assignedAt      : Time
        configCid       : ContractId Configuration.I
        reliability     : Decimal
        responsiveness  : Decimal
        accuracy        : Decimal
    where
        signatory operator
        observer party

        ensure reliability + responsiveness + accuracy == 1.0 
            && all (> 0.0) [reliability, responsiveness, accuracy]
        
        interface instance Role.I for TenantRole where
            view = Role.View with
                operator
                party
                assignedAt
                componentWeights = Map.fromList [
                  (Reliability, reliability), 
                  (Responsiveness, responsiveness), 
                  (Accuracy, accuracy)]